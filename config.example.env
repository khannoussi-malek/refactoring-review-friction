# Copy to config.env and edit. Choose a project whose contribution norms
# ENFORCE issue keys in commit messages — that drives your Filter-3 ceiling.
#
# Measured example (this kit): apache/commons-lang → only 17% of commits
# cite a LANG- key, because it routes most work through GitHub PRs. Projects
# with a mandated "[PROJECT-####]" commit convention (e.g. Hadoop, Kafka,
# HBase, Camel) typically sit far higher. Pick for traceability first.

PROJECT_KEY=HADOOP
REPO_URL=https://github.com/apache/hadoop.git
BRANCH=trunk

# Alternatives to compare citation rates across before committing:
#   KAFKA  https://github.com/apache/kafka.git      trunk
#   HBASE  https://github.com/apache/hbase.git      master
#   CAMEL  https://github.com/apache/camel.git      main
